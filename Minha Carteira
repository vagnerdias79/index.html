function regDiv(){
  const tk=document.getElementById('dvAtivo').value;
  const periodo=document.getElementById('dvPeriodo').value;
  const valor=parseFloat(document.getElementById('dvValor').value);
  const impostoValor=parseFloat(document.getElementById('dvImposto').value)||0;
