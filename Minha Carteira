function buildHistorico(){
  const filtAt=document.getElementById('hsFiltAt')?.value||'';
  const filtTp=document.getElementById('hsFiltTp')?.value||'';
  const filtBusca=(document.getElementById('hsFiltBusca')?.value||'').toUpperCase();

