function mkChart(canvasId,ref,labels,data,colors){
  if(ref) ref.destroy();
  const isDark=document.body.classList.contains('dark');
  const txtColor=isDark?'#8b95b0':'#64748b';
  const ctx=document.getElementById(canvasId).getContext('2d');
  return new Chart(ctx,{
    type:'doughnut',
    data:{labels,datasets:[{data,backgroundColor:colors,borderWidth:2,borderColor:isDark?'#161b27':'#ffffff',hoverOffset:6}]},
    options:{responsive:true,maintainAspectRatio:false,cutout:'58%',
      plugins:{legend:{position:'bottom',labels:{color:txtColor,font:{size:10},padding:8,boxWidth:12}},
        tooltip:{callbacks:{label:c=>{const tot=c.dataset.data.reduce((a,b)=>a+b,0); return c.label+': '+R(c.parsed)+' ('+(c.parsed/tot*100).toFixed(1)+'%)';}}}}},
    plugins:[{id:'pct',afterDatasetsDraw(chart){
      const {ctx,data}=chart; const tot=data.datasets[0].data.reduce((a,b)=>a+b,0);
      chart.getDatasetMeta(0).data.forEach((arc,i)=>{
        const pct=data.datasets[0].data[i]/tot*100; if(pct<4)return;
        const {x,y}=arc.tooltipPosition(); ctx.save();
