const R=v=>v.toLocaleString('pt-BR',{style:'currency',currency:'BRL'});
const U=v=>v.toLocaleString('en-US',{style:'currency',currency:'USD'});
const P=v=>(v>=0?'+':'')+v.toFixed(2)+'%';
const C=v=>v>=0?'pos':'neg';

// ═══════════════════ PREÇOS ═══════════════════
function pBRL(a){ const p=precos[a.ticker]; if(!p)return a.pmedio*(a.mercado==='US'?usdBrl:1); return p.moeda==='USD'?p.preco*usdBrl:p.preco; }
function pmBRL(a){ return a.mercado==='US'?a.pmedio*usdBrl:a.pmedio; }
function getP(a){ return precos[a.ticker]||{preco:a.pmedio,var:0,moeda:a.mercado==='US'?'USD':'BRL'}; }

function totais(){
  let pat=0,custo=0,vd=0;
  carteira.forEach(a=>{ const v=a.qtd*pBRL(a),c=a.qtd*pmBRL(a),p=getP(a); pat+=v;custo+=c;vd+=v*(p.var/100); });
  return {pat,custo,res:pat-custo,rp:custo?((pat-custo)/custo*100):0,vd,vdp:pat?(vd/pat*100):0};
}

