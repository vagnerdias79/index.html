    selAt.innerHTML='<option value="">Todos os ativos</option>'+tks.map(t=>'<option value="'+t+'"'+(t===cur?' selected':'')+'>'+t+'</option>').join('');
  }

  let lista=aportes.filter(a=>{
    if(filtAt&&a.ticker!==filtAt) return false;
    if(filtTp&&a.tipo!==filtTp) return false;
    if(filtBusca&&!a.ticker.includes(filtBusca)&&!a.nome.toUpperCase().includes(filtBusca)) return false;
    return true;
  });

  const tbody=document.getElementById('tbHist');
  if(!lista.length){ tbody.innerHTML='<tr><td colspan="12" style="text-align:center;color:var(--text2);padding:20px">Nenhum aporte encontrado.</td></tr>'; document.getElementById('hsResumo').innerHTML=''; return; }

  const tl={aporte:'Aporte',novo:'Cadastro',reinvestimento:'Reinvestimento',venda:'Venda'};
  const tc={aporte:'ta',novo:'tc',reinvestimento:'tf',venda:'tr'};
  let h='';
  [...lista].reverse().forEach(a=>{
    const isUS=a.moeda==='USD';
    const fmt=v=>isUS?U(v):R(v);
    const isVenda=a.tipo==='venda';
    const lucro=a.lucroLiqBRL;
    const lucroCell=isVenda?'<span class="'+(lucro>=0?'pos':'neg')+'" style="font-weight:600">'+R(lucro)+'</span>':'—';
    const irCell=isVenda&&a.imposto>0?'<span style="color:var(--red)">'+R(a.imposto)+'</span> ('+a.impAliq+'%)':'—';
    const liqIR=isVenda?(lucro-(a.imposto||0)):null;
    const liqCell=isVenda?'<span class="'+(liqIR>=0?'pos':'neg')+'" style="font-weight:600">'+R(liqIR)+'</span>':'—';
    const pmCell=isVenda?'<span style="font-size:10px;color:var(--text2)">'+fmt(a.pmAnterior)+'</span>':'<span style="color:var(--text2)">'+fmt(a.pmAnterior)+'</span> → <strong>'+fmt(a.pmNovo)+'</strong>';
    h+='<tr'+(isVenda?' style="background:rgba(248,114,114,.04)"':'')+'>';
    h+='<td style="font-size:11px;white-space:nowrap">'+a.data+'</td>';
    h+='<td><span class="tk">'+a.ticker+'</span></td>';
    h+='<td style="font-size:10px;color:var(--text2)">'+a.nome+'</td>';
    h+='<td><span class="tag '+(tc[a.tipo]||'ta')+'">'+tl[a.tipo]+'</span></td>';
    h+='<td style="font-size:11px">'+Number(a.qtd).toFixed(8)+'</td>';
    h+='<td style="font-size:11px">'+fmt(a.preco)+'</td>';
    h+='<td style="font-size:11px;color:var(--text2)">'+(isUS?'R$ '+Number(a.cambio).toFixed(4):'—')+'</td>';
    h+='<td style="font-size:11px;color:var(--text2)">'+(a.taxa>0?R(a.taxa):'—')+'</td>';
    h+='<td style="font-size:11px">'+fmt(a.valor)+'</td>';
    h+='<td style="font-size:11px;font-weight:600">'+R(a.valorBRL)+'</td>';
    h+='<td style="font-size:11px">'+lucroCell+'</td>';
    h+='<td style="font-size:11px">'+irCell+'</td>';
    h+='<td style="font-size:11px">'+liqCell+'</td>';
    h+='<td style="font-size:11px">'+pmCell+'</td>';
    h+='<td style="font-size:10px;color:var(--text2)">'+(a.obs||'—')+'</td>';
    h+='</tr>';
  });
  tbody.innerHTML=h;

  // Resumo
  const vendas=lista.filter(a=>a.tipo==='venda');
  const aportesBRL=lista.filter(a=>a.tipo!=='venda').reduce((s,a)=>s+a.valorBRL,0);
  const lucroTotal=vendas.reduce((s,a)=>s+(a.lucroLiqBRL||0),0);
  const irTotal=vendas.reduce((s,a)=>s+(a.imposto||0),0);
  let resumo='<div style="font-size:11px;color:var(--text2);margin-top:6px;display:flex;gap:20px;flex-wrap:wrap">';
  resumo+='<span>'+lista.length+' operação(ões)</span>';
  if(aportesBRL>0) resumo+='<span>Total aportado: <strong style="color:var(--accent)">'+R(aportesBRL)+'</strong></span>';
  if(vendas.length>0) resumo+='<span>Resultado vendas: <strong class="'+(lucroTotal>=0?'pos':'neg')+'">'+R(lucroTotal)+'</strong></span>';
  if(irTotal>0) resumo+='<span>IR estimado total: <strong style="color:var(--red)">'+R(irTotal)+'</strong></span>';
  resumo+='</div>';
  document.getElementById('hsResumo').innerHTML=resumo;
}

// ═══════════════════ REFRESH ═══════════════════
async function refresh(){
  setSt('l','Buscando cotações...');
  document.getElementById('btnR').disabled=true;
  await fetchAll();
  renderAll();
  const t=new Date();
  setSt('ok','Atualizado às '+t.toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit',second:'2-digit'})+' · USD/BRL '+usdBrl.toFixed(4));
  document.getElementById('btnR').disabled=false;
}

// INIT
loadTheme();
document.getElementById('lockPwd').focus();
setInterval(()=>{ if(document.getElementById('appContent').style.display!=='none') refresh(); },5*60*1000);
</script>
