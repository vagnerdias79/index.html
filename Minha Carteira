async function fetchCambio(){
  // Fonte 1: brapi currency endpoint
  try{
    const r=await fetch('https://brapi.dev/api/v2/currency?currency=USD-BRL&token='+TOK);
    const d=await r.json();
    const bid=d?.currency?.[0]?.bidPrice;
    if(bid&&bid>4&&bid<10){ usdBrl=bid; camUpd=new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit',second:'2-digit'}); return; }
  }catch(e){}
  // Fonte 2: brapi quote USDBRL=X
  try{
    const r=await fetch('https://brapi.dev/api/quote/USDBRL=X?token='+TOK);
    const d=await r.json();
    const p=d?.results?.[0]?.regularMarketPrice;
    if(p&&p>4&&p<10){ usdBrl=p; camUpd=new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit',second:'2-digit'}); return; }
  }catch(e){}
  // Fonte 3: exchangerate-api (pública, sem token)
  try{
    const r=await fetch('https://open.er-api.com/v6/latest/USD');
    const d=await r.json();
    const p=d?.rates?.BRL;
    if(p&&p>4&&p<10){ usdBrl=p; camUpd=new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit',second:'2-digit'})+' (ER-API)'; }
  }catch(e){}
}
async function fetchAll(){
  await fetchCambio();
  const ativos=carteira.filter(a=>!a.ticker.startsWith('TESE-'));
  for(let i=0;i<ativos.length;i++){
    const a=ativos[i];
    setSt('l','Buscando '+a.ticker+' ('+(i+1)+'/'+ativos.length+')...');
    try{
      const r=await fetch('https://brapi.dev/api/quote/'+a.ticker+'?token='+TOK);
      const d=await r.json();
      if(d.results&&d.results[0]){
        precos[a.ticker]={preco:d.results[0].regularMarketPrice,var:d.results[0].regularMarketChangePercent||0,moeda:a.mercado==='US'?'USD':'BRL'};
      } else if(!precos[a.ticker]) precos[a.ticker]={preco:a.pmedio,var:0,moeda:a.mercado==='US'?'USD':'BRL'};
    }catch(e){ if(!precos[a.ticker]) precos[a.ticker]={preco:a.pmedio,var:0,moeda:a.mercado==='US'?'USD':'BRL'}; }
    renderAll(); await new Promise(r=>setTimeout(r,250));
  }
  carteira.filter(a=>a.ticker.startsWith('TESE-')).forEach(a=>{ if(!precos[a.ticker]) precos[a.ticker]={preco:a.pmedio,var:0,moeda:'BRL'}; });
}

