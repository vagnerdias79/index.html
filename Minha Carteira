  dividendos.push({ticker:tk,periodo,valor,impostoValor,moeda:at&&at.mercado==='US'?'USD':'BRL',data,obs});
  save(); buildDividendos();
  document.getElementById('dvValor').value='';
  document.getElementById('dvImposto').value='';
  document.getElementById('dvPctCalc').textContent='0.0';
  document.getElementById('dvObs').value='';
  toast('✓ Dividendo registrado');
