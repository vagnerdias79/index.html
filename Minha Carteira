function cambioMedioCompra(tk){
  // Calcula câmbio médio ponderado dos aportes do ativo
  const aps=aportes.filter(a=>a.ticker===tk&&a.moeda==='USD');
  if(!aps.length) return usdBrl;
  const totalQtd=aps.reduce((s,a)=>s+a.qtd,0);
  const totalPonderado=aps.reduce((s,a)=>s+(a.cambio*a.qtd),0);
  return totalQtd>0?totalPonderado/totalQtd:usdBrl;
}

function calcImposto(tipo,mercado,lucroLiqBRL,qtdVendaBRL){
  let aliq=0, regra='';
  if(mercado==='US'){
    if(tipo==='etf'||tipo==='acao'){
      aliq=15; regra='Ganho de capital no exterior: alíquota de 15% sobre o lucro líquido em BRL.';
    }
  } else {
    if(tipo==='fii'){ aliq=20; regra='FII: alíquota de 20% sobre o lucro.'; }
    else if(tipo==='renda'){ aliq=17.5; regra='Renda Fixa: alíquota estimada de 17,5% (tabela regressiva — ajuste conforme prazo).'; }
    else if(tipo==='acao'){
      if(qtdVendaBRL<=20000){ aliq=0; regra='Ações BR: venda mensal ≤ R$20.000 — isento de IR. Verifique o total de vendas no mês.'; }
      else { aliq=15; regra='Ações BR: venda mensal > R$20.000 — alíquota de 15% sobre o lucro.'; }
    } else { aliq=15; regra='Alíquota padrão de 15% aplicada.'; }
  }
  return {aliq, imposto:lucroLiqBRL>0?lucroLiqBRL*(aliq/100):0, regra};
}

