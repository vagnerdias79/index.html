function calcRb(){
  const aporte=parseFloat(document.getElementById('simVal').value)||0;
  const dest=document.getElementById('simDest').value;
  const {pat}=totais(); const tot=pat+aporte;
  let us=0,br=0;
  carteira.forEach(a=>{ const v=a.qtd*pBRL(a); if(a.mercado==='US')us+=v; else br+=v; });
  let aus=0,abr=0;
  if(dest==='US'){aus=aporte;}else if(dest==='BR'){abr=aporte;}
  else{
    const fu=Math.max(0,tot*MUS/100-us),fb=Math.max(0,tot*MBR/100-br);
    const ft=fu+fb;
    if(ft===0){aus=aporte*MUS/100;abr=aporte*MBR/100;}else{aus=aporte*(fu/ft);abr=aporte*(fb/ft);}
  }
  let h='<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px">';
  h+='<div class="rc"><div><div class="rd">Aportar EUA</div><div class="ra">'+R(aus)+'</div><div class="rd">'+U(aus/usdBrl)+' · '+((aus/(aporte||1))*100).toFixed(1)+'%</div></div></div>';
  h+='<div class="rc"><div><div class="rd">Aportar Brasil</div><div class="ra">'+R(abr)+'</div><div class="rd">'+((abr/(aporte||1))*100).toFixed(1)+'% do aporte</div></div></div></div>';
  if(aus>0){
    const aetf=aus*METF/100,aac=aus*MACAO/100;
    const usAt=carteira.filter(a=>a.mercado==='US'&&(a.pesoAlvo||0)>0);
    const tpetf=usAt.filter(a=>a.tipo==='etf').reduce((s,a)=>s+(a.pesoAlvo||0),0);
    const tpac=usAt.filter(a=>a.tipo!=='etf').reduce((s,a)=>s+(a.pesoAlvo||0),0);
    h+='<div style="font-size:10px;color:var(--text2);text-transform:uppercase;margin-bottom:8px">Distribuição EUA</div><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">';
    usAt.sort((a,b)=>(b.pesoAlvo||0)-(a.pesoAlvo||0)).forEach(a=>{
      const ie=a.tipo==='etf',tb=ie?tpetf:tpac,bv=ie?aetf:aac;
      const v=tb?bv*(a.pesoAlvo||0)/tb:0,pr=precos[a.ticker]?.preco||a.pmedio;
      h+='<div class="rc"><div><span class="tk">'+a.ticker+'</span><span class="tag '+(ie?'te':'ta')+'" style="margin-left:5px">'+(ie?'ETF':'Ação')+'</span><div class="ra" style="font-size:13px">'+R(v)+'</div><div class="rd">'+U(v/usdBrl)+' · ~'+(v/(pr*usdBrl)).toFixed(4)+' cotas · alvo '+a.pesoAlvo+'%</div></div></div>';
    });
    h+='</div>';
  }
  if(abr>0){
    const arf=abr*MRF/100,aabr=abr*MABR/100,acx=abr*MCAIXA/100;
    h+='<div style="font-size:10px;color:var(--text2);text-transform:uppercase;margin:14px 0 8px">Distribuição Brasil</div><div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px">';
    h+='<div class="rc"><div><div class="rd">Renda Fixa (60%)</div><div class="ra">'+R(arf)+'</div></div></div>';
    h+='<div class="rc"><div><div class="rd">Ações/FIIs BR (30%)</div><div class="ra">'+R(aabr)+'</div></div></div>';
    h+='<div class="rc"><div><div class="rd">Caixa (10%)</div><div class="ra">'+R(acx)+'</div></div></div></div>';
  }
  document.getElementById('rbRes').innerHTML=h;
}

