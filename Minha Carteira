function vendaCalc(){
  const tk=document.getElementById('vTk').value;
  const at=carteira.find(a=>a.ticker===tk);
  if(!at) return;
  const isUS=at.mercado==='US';
  const qtd=parseFloat(document.getElementById('vQtd').value)||0;
  const preco=parseFloat(document.getElementById('vPreco').value)||0;
  const cambioV=isUS?(parseFloat(document.getElementById('vCambio').value)||usdBrl):1;
  const taxa=parseFloat(document.getElementById('vTaxa').value)||0;
  const box=document.getElementById('vCalcBox');
  if(!qtd||!preco){ box.style.display='none'; return; }
  box.style.display='block';
  const camMedComp=isUS?cambioMedioCompra(tk):1;
  // Valores em moeda original
  const bruto=qtd*preco; // USD ou BRL
  const custo=qtd*at.pmedio; // USD ou BRL (PM)
  // Converter para BRL
  const brutoBRL=isUS?bruto*cambioV:bruto;
  const custoBRL=isUS?custo*camMedComp:custo;
  const lucroOperBRL=brutoBRL-custoBRL;
  // Variação cambial (só EUA)
  const varCambioBRL=isUS?custo*(cambioV-camMedComp):0;
  const lucroLiqBRL=lucroOperBRL-taxa;
  const fmt=v=>isUS?U(v):R(v);
  document.getElementById('vResBruto').textContent=fmt(bruto)+' ('+R(brutoBRL)+')';
  document.getElementById('vResPM').textContent=fmt(at.pmedio);
  document.getElementById('vResCusto').textContent=fmt(custo)+' ('+R(custoBRL)+')';
  document.getElementById('vResLucro').innerHTML='<span class="'+(lucroOperBRL>=0?'pos':'neg')+'">'+R(lucroOperBRL)+'</span>';
  document.getElementById('vResCambioComp').textContent=isUS?'R$ '+camMedComp.toFixed(4):'—';
  document.getElementById('vResVarCambio').innerHTML=isUS?'<span class="'+(varCambioBRL>=0?'pos':'neg')+'">'+R(varCambioBRL)+'</span>':'—';
  document.getElementById('vResTaxa').textContent=taxa>0?R(taxa):'—';
  document.getElementById('vResLiq').innerHTML='<span class="'+(lucroLiqBRL>=0?'pos':'neg')+'"><strong>'+R(lucroLiqBRL)+'</strong></span>';
  // Imposto
  const {aliq,imposto,regra}=calcImposto(at.tipo,at.mercado,lucroLiqBRL,brutoBRL);
  document.getElementById('vImpRegra').textContent=regra;
  document.getElementById('vImpBase').value=Math.max(0,lucroLiqBRL).toFixed(2);
  document.getElementById('vImpAliq').value=aliq;
  document.getElementById('vImpValor').textContent=R(imposto);
  document.getElementById('vResAfterIR').textContent=R(lucroLiqBRL-imposto);
  document.getElementById('vResAfterIR').className=lucroLiqBRL-imposto>=0?'pos':'neg';
}

