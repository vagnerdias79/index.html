function reinvestDiv(){
  const destTk=document.getElementById('dvReinvest').value;
  const valor=parseFloat(document.getElementById('dvValor').value);
  if(!destTk){ alert('Escolha o ativo de destino.'); return; }
  if(!valor||valor<=0){ alert('Informe o valor a reinvestir.'); return; }
  const idx=carteira.findIndex(a=>a.ticker===destTk);
  if(idx<0){ alert('Ativo não encontrado.'); return; }
  const a=carteira[idx];
  const isUS=a.mercado==='US';
  const valorNaMoeda=isUS?valor/usdBrl:valor; // valor vem em USD ou BRL
  const pr=precos[a.ticker]?.preco||a.pmedio;
  const qtdExtra=valorNaMoeda/pr;
  const custoAtual=a.qtd*a.pmedio;
  carteira[idx].qtd+=qtdExtra;
  carteira[idx].pmedio=(custoAtual+valorNaMoeda)/carteira[idx].qtd;
  aportes.push({ticker:destTk,nome:a.nome,data:new Date().toLocaleDateString('pt-BR'),tipo:'reinvestimento',valor:valorNaMoeda,preco:pr,cambio:isUS?usdBrl:1,taxa:0,qtd:qtdExtra,valorBRL:valor,moeda:isUS?'USD':'BRL',pmAnterior:a.pmedio,pmNovo:carteira[idx].pmedio,obs:'Reinvestimento de dividendo'});
  save(); renderAll(); buildHistorico();
  toast('✓ Reinvestido em '+destTk+' (+'+qtdExtra.toFixed(8)+' cotas)');
}

