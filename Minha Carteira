    const r=await fetch('https://brapi.dev/api/quote/'+tk+'?token='+TOK);
    const d=await r.json();
    if(d.results&&d.results[0]){
      const res=d.results[0];
      const nome=res.longName||res.shortName||tk;
      const cotacao=res.regularMarketPrice||0;
      const moeda=mk==='US'?'USD':'BRL';
      // Tentar inferir tipo
      let tipo='acao';
